{
  "info": {
    "name": "Order Management API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.environment.set('token', json.access_token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@orders.com\",\n  \"password\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Criar pedido",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"number\": \"ORD-010\",\n  \"estimatedDeliveryDate\": \"2026-07-15\",\n  \"customerName\": \"João Silva\",\n  \"customerDocument\": \"123.456.789-00\",\n  \"deliveryAddress\": \"Rua das Flores, 123 - São Paulo, SP\",\n  \"items\": [\n    {\n      \"description\": \"Camiseta azul tamanho M\",\n      \"quantity\": 2,\n      \"unitPrice\": 49.90\n    },\n    {\n      \"description\": \"Calça jeans\",\n      \"quantity\": 1,\n      \"unitPrice\": 199.90\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/orders",
              "host": ["{{baseUrl}}"],
              "path": ["orders"]
            }
          }
        },
        {
          "name": "Listar pedidos",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/orders",
              "host": ["{{baseUrl}}"],
              "path": ["orders"]
            }
          }
        },
        {
          "name": "Filtrar por número",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/orders?number=ORD-001",
              "host": ["{{baseUrl}}"],
              "path": ["orders"],
              "query": [
                { "key": "number", "value": "ORD-001" }
              ]
            }
          }
        },
        {
          "name": "Filtrar por status",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/orders?status=PENDING",
              "host": ["{{baseUrl}}"],
              "path": ["orders"],
              "query": [
                { "key": "status", "value": "PENDING" }
              ]
            }
          }
        },
        {
          "name": "Filtrar por período",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/orders?startDate=2026-01-01&endDate=2026-12-31",
              "host": ["{{baseUrl}}"],
              "path": ["orders"],
              "query": [
                { "key": "startDate", "value": "2026-01-01" },
                { "key": "endDate", "value": "2026-12-31" }
              ]
            }
          }
        },
        {
          "name": "Buscar pedido por ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/orders/:id",
              "host": ["{{baseUrl}}"],
              "path": ["orders", ":id"],
              "variable": [
                { "key": "id", "value": "" }
              ]
            }
          }
        },
        {
          "name": "Editar pedido",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"PROCESSING\",\n  \"deliveryAddress\": \"Av. Paulista, 1000 - São Paulo, SP\",\n  \"estimatedDeliveryDate\": \"2026-08-01\",\n  \"items\": [\n    {\n      \"description\": \"Camiseta vermelha tamanho M\",\n      \"quantity\": 2,\n      \"unitPrice\": 49.90\n    },\n    {\n      \"description\": \"Calça jogger\",\n      \"quantity\": 1,\n      \"unitPrice\": 199.90\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/orders/:id",
              "host": ["{{baseUrl}}"],
              "path": ["orders", ":id"],
              "variable": [
                { "key": "id", "value": "" }
              ]
            }
          }
        },
        {
          "name": "Deletar pedido (soft delete)",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/orders/:id",
              "host": ["{{baseUrl}}"],
              "path": ["orders", ":id"],
              "variable": [
                { "key": "id", "value": "" }
              ]
            }
          }
        }
      ]
    }
  ]
}
